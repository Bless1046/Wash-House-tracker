<div class="toast" id="toast"></div>

<script>
/* ======================================================================
   CONFIG — fill these in with your Supabase project details, then run
   schema.sql (shipped alongside this file) in the Supabase SQL editor.
   ====================================================================== */
const SUPABASE_URL = "https://eillmgvqgaqksfsdbzez.supabase.co";
const SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVpbGxtZ3ZxZ2Fxa3Nmc2RiemV6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODM1ODM0MjEsImV4cCI6MjA5OTE1OTQyMX0.Z_HKqT7NBYTpM_OLyEvJPlUPGUBzbbI-JA2Wa6F0Ybg";

let supa = null;
let jobs = [];
let editingId = null;

const METRIC_COLOR_VAR = {
  'Easy':'var(--metric-easy)', 'Medium':'var(--metric-medium)',
  'Hard':'var(--metric-hard)', 'Very Hard':'var(--metric-veryhard)'
};

function initSupabase(){
  if(!SUPABASE_URL || SUPABASE_URL === "YOUR_SUPABASE_URL" || !SUPABASE_ANON_KEY || SUPABASE_ANON_KEY === "YOUR_SUPABASE_ANON_KEY"){
    document.getElementById('configWarning').style.display = 'block';
    return false;
  }
  supa = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
  return true;
}

/* ---------------- Tabs ---------------- */
document.querySelectorAll('nav.tabs button').forEach(btn=>{
  btn.addEventListener('click', ()=>{
    document.querySelectorAll('nav.tabs button').forEach(b=>b.classList.remove('active'));
    document.querySelectorAll('section.tab').forEach(s=>s.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('tab-'+btn.dataset.tab).classList.add('active');
    if(btn.dataset.tab === 'dashboard') renderDashboard();
  });
});

/* ---------------- Toast ---------------- */
function toast(msg, isErr){
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast show' + (isErr ? ' err' : '');
  setTimeout(()=>t.classList.remove('show'), 2600);
}

function escAttr(s){
  return String(s ?? '').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}
function metricPillClass(m){
  return {'Easy':'pill-easy','Medium':'pill-medium','Hard':'pill-hard','Very Hard':'pill-veryhard'}[m] || 'pill-medium';
}

/* ---------------- Delivery drop rows ---------------- */
function createDropRow(drop_no, date, units){
  const row = document.createElement('div');
  row.className = 'drop-row';
  row.innerHTML = `
    <select class="drop-select">
      <option value="1st">1st</option><option value="2nd">2nd</option>
      <option value="3rd">3rd</option><option value="4th">4th</option>
    </select>
    <input type="date" class="drop-date">
    <input type="number" class="drop-units" min="0" value="0">
    <button type="button" class="remove-drop-btn" title="Remove drop">✕</button>
  `;
  row.querySelector('.drop-select').value = drop_no || '1st';
  row.querySelector('.drop-date').value = date || '';
  row.querySelector('.drop-units').value = units || 0;
  row.querySelector('.remove-drop-btn').addEventListener('click', ()=>{ row.remove(); updateDropTotal(); });
  row.querySelector('.drop-units').addEventListener('input', updateDropTotal);
  return row;
}
function addDropRow(drop_no, date, units){
  document.getElementById('dropsContainer').appendChild(createDropRow(drop_no, date, units));
  updateDropTotal();
}
function clearDropsContainer(){
  document.getElementById('dropsContainer').innerHTML = '';
}
function getDropsFromForm(){
  return [...document.querySelectorAll('#dropsContainer .drop-row')].map(row=>({
    drop_no: row.querySelector('.drop-select').value,
    date: row.querySelector('.drop-date').value || null,
    units: Number(row.querySelector('.drop-units').value) || 0
  }));
}
function updateDropTotal(){
  const drops = getDropsFromForm();
  const total = drops.reduce((s,d)=>s+(d.units||0),0);
  const planned = Number(document.getElementById('planned_units').value) || 0;
  const pct = planned > 0 ? Math.min(100, Math.round(total/planned*100)) : 0;
  document.getElementById('dropTotal').textContent = `Total received: ${total} / ${planned} planned (${pct}%)`;
}
document.getElementById('addDropBtn').addEventListener('click', ()=>addDropRow('1st','',0));
document.getElementById('planned_units').addEventListener('input', updateDropTotal);
addDropRow('1st','',0); // starting blank row

/* ---------------- Form <-> object ---------------- */
function readForm(){
  const drops = getDropsFromForm();
  const units_received = drops.reduce((s,d)=>s+(d.units||0),0);
  return {
    cmt_name: document.getElementById('cmt_name').value.trim(),
    style_number: document.getElementById('style_number').value.trim(),
    order_number: document.getElementById('order_number').value.trim(),
    start_date: document.getElementById('start_date').value || null,
    style_delivery_date: document.getElementById('style_delivery_date').value || null,
    process: document.getElementById('process').value.trim(),
    wash_metric: document.getElementById('wash_metric').value,
    days_in_washing: Number(document.getElementById('days_in_washing').value) || 0,
    planned_units: Number(document.getElementById('planned_units').value) || 0,
    sample_received: document.querySelector('input[name=sample_received]:checked').value === 'yes',
    units_received: units_received,
    units_despatched: Number(document.getElementById('units_despatched').value) || 0,
    drops: drops,
    last_drop_date: document.getElementById('last_drop_date').value || null,
    balance_laundry: Number(document.getElementById('balance_laundry').value) || 0,
    balance_production: Number(document.getElementById('balance_production').value) || 0,
    balance_spraying: Number(document.getElementById('balance_spraying').value) || 0,
    balance_manual: Number(document.getElementById('balance_manual').value) || 0,
    balance_laser: Number(document.getElementById('balance_laser').value) || 0,
    balance_finishing: Number(document.getElementById('balance_finishing').value) || 0,
  };
}

function fillForm(job){
  document.getElementById('cmt_name').value = job.cmt_name || '';
  document.getElementById('style_number').value = job.style_number || '';
  document.getElementById('order_number').value = job.order_number || '';
  document.getElementById('start_date').value = job.start_date || '';
  document.getElementById('style_delivery_date').value = job.style_delivery_date || '';
  document.getElementById('process').value = job.process || '';
  document.getElementById('wash_metric').value = job.wash_metric || 'Medium';
  document.getElementById('days_in_washing').value = job.days_in_washing || 0;
  document.getElementById('planned_units').value = job.planned_units || 0;
  document.querySelector(`input[name=sample_received][value=${job.sample_received ? 'yes' : 'no'}]`).checked = true;
  document.getElementById('units_despatched').value = job.units_despatched || 0;
  document.getElementById('last_drop_date').value = job.last_drop_date || '';
  document.getElementById('balance_laundry').value = job.balance_laundry || 0;
  document.getElementById('balance_production').value = job.balance_production || 0;
  document.getElementById('balance_spraying').value = job.balance_spraying || 0;
  document.getElementById('balance_manual').value = job.balance_manual || 0;
  document.getElementById('balance_laser').value = job.balance_laser || 0;
  document.getElementById('balance_finishing').value = job.balance_finishing || 0;

  clearDropsContainer();
  const drops = (job.drops && job.drops.length) ? job.drops : [{drop_no:'1st', date:'', units:0}];
  drops.forEach(d=>addDropRow(d.drop_no, d.date, d.units));
}

function resetForm(){
  document.getElementById('jobForm').reset();
  document.getElementById('wash_metric').value = 'Medium';
  document.getElementById('last_drop_date').value = '';
  clearDropsContainer();
  addDropRow('1st','',0);
  editingId = null;
  document.getElementById('formTitle').textContent = 'New Job Card';
  document.getElementById('formModeChip').textContent = 'CREATE';
  document.getElementById('submitBtn').textContent = 'Save Job Card';
  document.getElementById('cancelEditBtn').style.display = 'none';
}
document.getElementById('cancelEditBtn').addEventListener('click', resetForm);

/* ---------------- CRUD ---------------- */
document.getElementById('jobForm').addEventListener('submit', async (e)=>{
  e.preventDefault();
  const data = readForm();
  if(!data.cmt_name || !data.style_number || !data.order_number){
    toast('CMT name, style number and order number are required.', true);
    return;
  }
  try{
    if(editingId){
      if(supa){
        const {error} = await supa.from('wash_jobs').update(data).eq('id', editingId);
        if(error) throw error;
      }
      const idx = jobs.findIndex(j=>j.id === editingId);
      if(idx > -1) jobs[idx] = {...jobs[idx], ...data};
      toast('Job card updated.');
    } else {
      if(supa){
        const {data: inserted, error} = await supa.from('wash_jobs').insert(data).select();
        if(error) throw error;
        jobs.unshift(inserted[0]);
      } else {
        jobs.unshift({...data, id: 'local-'+Date.now(), created_at: new Date().toISOString()});
      }
      toast('Job card added.');
    }
    resetForm();
    renderJobsTable();
    populateProcessFilter();
  }catch(err){
    console.error(err);
    toast('Save failed: ' + (err.message || err), true);
  }
});

async function deleteJob(id){
  if(!confirm('Delete this job card? This cannot be undone.')) return;
  try{
    if(supa){
      const {error} = await supa.from('wash_jobs').delete().eq('id', id);
      if(error) throw error;
    }
    jobs = jobs.filter(j=>j.id !== id);
    renderJobsTable();
    populateProcessFilter();
    toast('Job card deleted.');
  }catch(err){
    console.error(err);
    toast('Delete failed: ' + (err.message || err), true);
  }
}

function editJob(id){
  const job = jobs.find(j=>j.id === id);
  if(!job) return;
  editingId = id;
  fillForm(job);
  document.getElementById('formTitle').textContent = 'Edit Job Card';
  document.getElementById('formModeChip').textContent = 'EDIT';
  document.getElementById('submitBtn').textContent = 'Update Job Card';
  document.getElementById('cancelEditBtn').style.display = 'inline-block';
  document.querySelector('[data-tab=jobcard]').click();
  window.scrollTo({top:0, behavior:'smooth'});
}

async function loadJobs(){
  if(!supa) return;
  try{
    const {data, error} = await supa.from('wash_jobs').select('*').order('created_at', {ascending:false});
    if(error) throw error;
    jobs = data || [];
    renderJobsTable();
    populateProcessFilter();
  }catch(err){
    console.error(err);
    toast('Could not load job cards: ' + (err.message || err), true);
  }
}

/* ---------------- Table render / filter ---------------- */
function populateProcessFilter(){
  const sel = document.getElementById('filterProcess');
  const current = sel.value;
  const procs = [...new Set(jobs.map(j=>j.process).filter(Boolean))].sort();
  sel.innerHTML = '<option value="">All Processes</option>' + procs.map(p=>`<option value="${escAttr(p)}">${escAttr(p)}</option>`).join('');
  sel.value = current;
}

function filteredJobs(){
  const q = document.getElementById('searchBox').value.trim().toLowerCase();
  const proc = document.getElementById('filterProcess').value;
  const metric = document.getElementById('filterMetric').value;
  return jobs.filter(j=>{
    if(proc && j.process !== proc) return false;
    if(metric && j.wash_metric !== metric) return false;
    if(q){
      const hay = `${j.cmt_name} ${j.style_number} ${j.order_number}`.toLowerCase();
      if(!hay.includes(q)) return false;
    }
    return true;
  });
}

function renderJobsTable(){
  const tbody = document.getElementById('jobsTableBody');
  const list = filteredJobs();
  document.getElementById('jobCountChip').textContent = jobs.length;
  if(list.length === 0){
    tbody.innerHTML = '<tr class="empty-row"><td colspan="12">No job cards match — add one, or clear filters.</td></tr>';
    return;
  }
  tbody.innerHTML = list.map(j=>`
    <tr style="border-left:4px solid ${METRIC_COLOR_VAR[j.wash_metric] || 'var(--line)'};">
      <td>${escAttr(j.cmt_name)}</td>
      <td class="mono">${escAttr(j.style_number)}</td>
      <td class="mono">${escAttr(j.order_number)}</td>
      <td>${escAttr(j.process || '—')}</td>
      <td><span class="pill ${metricPillClass(j.wash_metric)}">${escAttr(j.wash_metric || '—')}</span></td>
      <td>${j.days_in_washing ?? '—'}</td>
      <td>${j.style_delivery_date || '—'}</td>
      <td>${j.planned_units ?? 0}</td>
      <td>${j.units_received ?? 0}</td>
      <td>${j.units_despatched ?? 0}</td>
      <td>${j.last_drop_date || '—'}</td>
      <td>
        <button class="icon-btn" title="Edit" onclick="editJob('${j.id}')">✏️</button>
        <button class="icon-btn" title="Delete" onclick="deleteJob('${j.id}')">🗑️</button>
      </td>
    </tr>
  `).join('');
}

document.getElementById('searchBox').addEventListener('input', renderJobsTable);
document.getElementById('filterProcess').addEventListener('change', renderJobsTable);
document.getElementById('filterMetric').addEventListener('change', renderJobsTable);

/* ---------------- Dashboard ---------------- */
function renderDashboard(){
  const total = jobs.length;
  const planned = jobs.reduce((s,j)=>s + (j.planned_units||0), 0);
  const received = jobs.reduce((s,j)=>s + (j.units_received||0), 0);
  const despatched = jobs.reduce((s,j)=>s + (j.units_despatched||0), 0);
  const late = jobs.filter(j=>j.last_drop_date && j.style_delivery_date && j.last_drop_date > j.style_delivery_date).length;

  document.getElementById('kpiJobs').textContent = total;
  document.getElementById('kpiPlanned').textContent = planned.toLocaleString();
  document.getElementById('kpiReceived').textContent = received.toLocaleString();
  document.getElementById('kpiDespatched').textContent = despatched.toLocaleString();
  document.getElementById('kpiLate').textContent = late;

  renderGantt();
  renderProgressList();
  renderBalanceChart();
  renderProcessList();
  renderMetricChart();
}

function renderGantt(){
  const inner = document.getElementById('ganttInner');
  const rows = jobs.filter(j=>j.start_date && (j.style_delivery_date || j.last_drop_date));
  if(rows.length === 0){
    inner.innerHTML = '<div class="empty-state" id="ganttEmpty"><div class="big">📅</div>Add job cards with a start date to see the timeline.</div>';
    return;
  }

  const allDates = [];
  rows.forEach(j=>{
    allDates.push(new Date(j.start_date));
    if(j.style_delivery_date) allDates.push(new Date(j.style_delivery_date));
    if(j.last_drop_date) allDates.push(new Date(j.last_drop_date));
  });
  allDates.push(new Date());
  let minD = new Date(Math.min(...allDates));
  let maxD = new Date(Math.max(...allDates));
  minD.setDate(minD.getDate() - 4);
  maxD.setDate(maxD.getDate() + 4);
  const totalMs = maxD - minD;

  function pct(d){ return ((new Date(d) - minD) / totalMs) * 100; }

  let monthsHtml = '';
  let gridHtml = '';
  let cursor = new Date(minD.getFullYear(), minD.getMonth(), 1);
  while(cursor <= maxD){
    const left = pct(cursor);
    if(left >= 0){
      monthsHtml += `<div class="gantt-month" style="left:${left}%">${cursor.toLocaleString('default',{month:'short', year:'2-digit'})}</div>`;
      gridHtml += `<div class="gantt-gridline" style="left:${left}%"></div>`;
    }
    cursor = new Date(cursor.getFullYear(), cursor.getMonth()+1, 1);
  }
  const todayPct = pct(new Date());

  const rowsHtml = rows.map(j=>{
    const planStart = pct(j.start_date);
    const planEnd = j.style_delivery_date ? pct(j.style_delivery_date) : planStart;
    const planWidth = Math.max(planEnd - planStart, 0.5);
    const metricClass = 'wm-' + (j.wash_metric || 'Medium').toLowerCase().replace(' ','');

    let actualBar = '';
    if(j.last_drop_date){
      const actEnd = pct(j.last_drop_date);
      const actWidth = Math.max(actEnd - planStart, 0.5);
      const isLate = j.style_delivery_date && j.last_drop_date > j.style_delivery_date;
      actualBar = `<div class="bar bar-actual ${isLate?'late':''}" style="left:${planStart}%; width:${actWidth}%;" title="Actual: ${j.start_date} → ${j.last_drop_date}${isLate?' (LATE)':''}"></div>`;
    }

    return `
      <div class="gantt-row">
        <div class="gantt-row-label"><b>${escAttr(j.style_number)}</b><span>${escAttr(j.cmt_name)}</span></div>
        <div class="gantt-track">
          ${gridHtml}
          <div class="gantt-today" style="left:${todayPct}%"></div>
          <div class="bar bar-plan ${metricClass}" style="left:${planStart}%; width:${planWidth}%;" title="Planned: ${j.start_date} → ${j.style_delivery_date||'—'}"></div>
          ${actualBar}
        </div>
      </div>`;
  }).join('');

  inner.innerHTML = `
    <div class="gantt-header" style="margin-left:190px;">${monthsHtml}</div>
    <div class="gantt-body">${rowsHtml}</div>
  `;
}

function renderProgressList(){
  const el = document.getElementById('progressList');
  if(jobs.length === 0){
    el.innerHTML = '<div class="empty-state">No data yet.</div>';
    return;
  }
  el.innerHTML = jobs.map(j=>{
    const planned = j.planned_units || 0;
    const received = j.units_received || 0;
    const pct = planned > 0 ? Math.min(100, Math.round(received/planned*100)) : 0;
    const color = METRIC_COLOR_VAR[j.wash_metric] || 'var(--denim)';
    return `
      <div class="progress-row">
        <div class="progress-label"><b>${escAttr(j.style_number)}</b><span>${escAttr(j.cmt_name)}</span></div>
        <div class="progress-bar-bg"><div class="progress-bar-fill" style="width:${pct}%; background:${color};"></div></div>
        <div class="progress-pct mono">${received}/${planned} (${pct}%)</div>
        <div class="progress-last">${j.last_drop_date ? 'Last drop: '+j.last_drop_date : 'No drops recorded'}</div>
      </div>`;
  }).join('');
}

function renderBalanceChart(){
  const fields = [
    ['Laundry','balance_laundry'], ['Production','balance_production'], ['Spraying','balance_spraying'],
    ['Manual','balance_manual'], ['Laser','balance_laser'], ['Finishing','balance_finishing']
  ];
  const totals = fields.map(([label,key])=>[label, jobs.reduce((s,j)=>s+(j[key]||0),0)]);
  const max = Math.max(...totals.map(t=>t[1]), 1);
  const el = document.getElementById('balChart');
  if(jobs.length === 0){ el.innerHTML = '<div class="empty-state">No data yet.</div>'; return; }
  el.innerHTML = totals.map(([label,val])=>`
    <div class="bal-item">
      <div>${label}</div>
      <div class="bal-bar-bg"><div class="bal-bar-fill" style="width:${(val/max*100).toFixed(1)}%"></div></div>
      <div class="mono" style="text-align:right;">${val}</div>
    </div>
  `).join('');
}

function renderProcessList(){
  const el = document.getElementById('procList');
  if(jobs.length === 0){ el.innerHTML = '<div class="empty-state">No data yet.</div>'; return; }
  const counts = {};
  jobs.forEach(j=>{
    const p = j.process || 'Unspecified';
    counts[p] = (counts[p]||0) + 1;
  });
  const sorted = Object.entries(counts).sort((a,b)=>b[1]-a[1]);
  el.innerHTML = sorted.map(([p,c])=>`<div class="proc-item"><span>${escAttr(p)}</span><b>${c}</b></div>`).join('');
}

function renderMetricChart(){
  const metrics = ['Easy','Medium','Hard','Very Hard'];
  const counts = metrics.map(m=>[m, jobs.filter(j=>j.wash_metric===m).length]);
  const max = Math.max(...counts.map(c=>c[1]), 1);
  const el = document.getElementById('metricChart');
  if(jobs.length === 0){ el.innerHTML = '<div class="empty-state">No data yet.</div>'; return; }
  el.innerHTML = counts.map(([m,c])=>`
    <div class="bal-item">
      <div><span class="pill ${metricPillClass(m)}">${m}</span></div>
      <div class="bal-bar-bg"><div class="bal-bar-fill" style="width:${(c/max*100).toFixed(1)}%; background:${METRIC_COLOR_VAR[m]};"></div></div>
      <div class="mono" style="text-align:right;">${c}</div>
    </div>
  `).join('');
}

/* ---------------- Init ---------------- */
window.addEventListener('load', ()=>{
  const ok = initSupabase();
  if(ok){
    loadJobs();
  } else {
    renderJobsTable();
  }
});
</script>
