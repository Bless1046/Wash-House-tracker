<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Wash House Process Tracker</title>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">
<style>
  :root{
    --purple:#6c2c84;
    --lime:#8dc63f;
    --navy:#1F3864;
    --denim:#3d5a80;
    --denim-dark:#2b4160;
    --denim-light:#d7e2ee;
    --chambray:#eef2f6;
    --paper:#faf9f6;
    --rivet:#c98a3e;
    --thread:#d97706;
    --ink:#20242c;
    --muted:#6b7280;
    --line:#dde3ea;
    --ok:#4a8c3f;
    --hard-red:#b3452c;
    --radius:10px;
    --shadow:0 1px 2px rgba(20,25,40,.06), 0 4px 14px rgba(20,25,40,.05);

    /* Wash metric colour scheme */
    --metric-easy:#92D050;
    --metric-easy-text:#2f5613;
    --metric-medium:#FFC000;
    --metric-medium-text:#6b4700;
    --metric-hard:#FFFF00;
    --metric-hard-text:#6b6b00;
    --metric-veryhard:#D86DCD;
    --metric-veryhard-text:#5c1a54;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    font-family:'Inter',system-ui,sans-serif;
    background:var(--paper);
    color:var(--ink);
    background-image:radial-gradient(circle at 1px 1px, rgba(61,90,128,0.06) 1px, transparent 0);
    background-size:22px 22px;
  }
  h1,h2,h3,.label-font{font-family:'Oswald',sans-serif; text-transform:uppercase; letter-spacing:.03em;}
  .mono{font-family:'JetBrains Mono',monospace;}

  /* ---------- Header ---------- */
  header.top{
    background:linear-gradient(135deg,var(--navy),var(--denim-dark));
    color:#fff; padding:18px 28px;
    display:flex; align-items:center; justify-content:space-between;
    box-shadow:var(--shadow); position:sticky; top:0; z-index:50;
  }
  .brand{display:flex; align-items:center; gap:12px;}
  .brand .tag{
    width:38px;height:38px;border-radius:6px; background:var(--lime);
    display:flex;align-items:center;justify-content:center;
    font-family:'Oswald',sans-serif; font-weight:700; color:var(--navy); font-size:15px;
    box-shadow:inset 0 0 0 2px rgba(255,255,255,.5); transform:rotate(-3deg);
  }
  .brand h1{margin:0; font-size:19px; color:#fff; letter-spacing:.04em;}
  .brand .sub{font-size:11px; color:var(--lime); text-transform:uppercase; letter-spacing:.12em; margin-top:2px;}

  nav.tabs{display:flex; gap:6px;}
  nav.tabs button{
    font-family:'Oswald',sans-serif; background:transparent; border:1px solid rgba(255,255,255,.25);
    color:rgba(255,255,255,.75); padding:9px 18px; border-radius:7px; cursor:pointer;
    font-size:13px; letter-spacing:.06em; text-transform:uppercase; transition:.15s;
  }
  nav.tabs button.active{background:var(--lime); border-color:var(--lime); color:var(--navy); font-weight:600;}
  nav.tabs button:not(.active):hover{background:rgba(255,255,255,.1);}

  main{padding:26px 28px 60px; max-width:1440px; margin:0 auto;}
  section.tab{display:none;}
  section.tab.active{display:block; animation:fade .25s ease;}
  @keyframes fade{from{opacity:0; transform:translateY(4px)} to{opacity:1; transform:none}}

  /* ---------- Card / tag ---------- */
  .card{background:#fff; border-radius:var(--radius); box-shadow:var(--shadow); border:1px solid var(--line);}
  .tag-card{position:relative; background:#fff; border-radius:var(--radius); box-shadow:var(--shadow); padding:22px 24px 20px; border:2px dashed var(--denim-light);}
  .tag-card::before, .tag-card::after{content:""; position:absolute; width:7px; height:7px; border-radius:50%; background:var(--rivet); box-shadow:0 0 0 2px #fff, inset 0 -1px 1px rgba(0,0,0,.3); top:10px;}
  .tag-card::before{left:10px;}
  .tag-card::after{right:10px;}

  .section-title{display:flex; align-items:center; gap:10px; margin:0 0 16px; font-size:16px; color:var(--denim-dark);}
  .section-title .chip{background:var(--denim); color:#fff; font-size:11px; font-family:'JetBrains Mono',monospace; padding:2px 8px; border-radius:20px; letter-spacing:0;}

  /* ---------- Job Card layout ---------- */
  .jobcard-grid{display:grid; grid-template-columns:minmax(360px,460px) 1fr; gap:22px; align-items:start;}
  @media (max-width:1050px){.jobcard-grid{grid-template-columns:1fr;}}

  .field-grid{display:grid; grid-template-columns:1fr 1fr; gap:12px 14px;}
  .field-grid .full{grid-column:1/-1;}
  label{display:block; font-size:11.5px; font-weight:600; color:var(--muted); text-transform:uppercase; letter-spacing:.05em; margin-bottom:5px;}
  input[type=text], input[type=date], input[type=number], select{
    width:100%; padding:9px 10px; border:1px solid var(--line); border-radius:7px;
    font-size:13.5px; font-family:'Inter',sans-serif; background:var(--chambray); transition:.15s;
  }
  input:focus, select:focus{outline:none; border-color:var(--denim); background:#fff; box-shadow:0 0 0 3px rgba(61,90,128,.12);}
  .radio-row{display:flex; gap:14px; padding:9px 2px;}
  .radio-row label{display:flex; align-items:center; gap:6px; font-size:12.5px; text-transform:none; letter-spacing:0; font-weight:500; color:var(--ink); margin:0;}
  .radio-row input{width:auto;}

  fieldset{border:1px solid var(--line); border-radius:8px; padding:12px 14px 14px; margin:0;}
  legend{font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:var(--denim); padding:0 6px;}
  .balance-grid{display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px;}

  .btn{font-family:'Oswald',sans-serif; letter-spacing:.04em; text-transform:uppercase; border:none; border-radius:7px; padding:11px 20px; font-size:13px; cursor:pointer; transition:.15s;}
  .btn-primary{background:var(--denim); color:#fff;}
  .btn-primary:hover{background:var(--denim-dark);}
  .btn-ghost{background:transparent; border:1px solid var(--line); color:var(--muted);}
  .btn-ghost:hover{border-color:var(--denim); color:var(--denim);}
  .btn-sm{padding:7px 12px; font-size:11.5px;}
  .form-actions{display:flex; gap:10px; margin-top:18px;}

  /* Delivery planning / drops */
  .drops-table{display:flex; flex-direction:column; gap:6px;}
  .drops-head{display:grid; grid-template-columns:82px 1fr 1fr 28px; gap:8px; font-size:10px; text-transform:uppercase; letter-spacing:.05em; color:var(--muted); font-weight:700; padding:0 2px 2px;}
  .drop-row{display:grid; grid-template-columns:82px 1fr 1fr 28px; gap:8px; align-items:center;}
  .drop-row select, .drop-row input{padding:7px 8px; font-size:12.5px;}
  .remove-drop-btn{background:none; border:none; cursor:pointer; color:var(--muted); font-size:13px; padding:4px;}
  .remove-drop-btn:hover{color:var(--hard-red);}
  .drop-total{margin-top:10px; font-size:12.5px; font-weight:600; color:var(--denim-dark);}
  #addDropBtn{margin-top:10px;}

  /* ---------- Jobs table ---------- */
  .table-toolbar{display:flex; gap:10px; margin-bottom:14px; align-items:center; flex-wrap:wrap;}
  .table-toolbar input[type=text]{max-width:220px;}
  .table-toolbar select{max-width:170px;}
  .table-wrap{overflow-x:auto; border-radius:var(--radius);}
  table{width:100%; border-collapse:collapse; font-size:12.5px;}
  thead th{background:var(--denim); color:#fff; text-align:left; padding:9px 10px; font-family:'Oswald',sans-serif; font-size:11px; text-transform:uppercase; letter-spacing:.04em; white-space:nowrap; position:sticky; top:0;}
  tbody td{padding:9px 10px; border-bottom:1px solid var(--line); white-space:nowrap;}
  tbody tr:hover{background:var(--chambray);}
  .pill{padding:3px 9px; border-radius:20px; font-size:11px; font-weight:700;}
  .pill-easy{background:var(--metric-easy); color:var(--metric-easy-text);}
  .pill-medium{background:var(--metric-medium); color:var(--metric-medium-text);}
  .pill-hard{background:var(--metric-hard); color:var(--metric-hard-text);}
  .pill-veryhard{background:var(--metric-veryhard); color:var(--metric-veryhard-text);}
  .icon-btn{background:none; border:none; cursor:pointer; font-size:14px; padding:3px 6px; border-radius:5px; color:var(--muted);}
  .icon-btn:hover{background:var(--chambray); color:var(--denim);}
  .empty-row td{text-align:center; color:var(--muted); padding:30px; font-style:italic;}

  /* ---------- Dashboard ---------- */
  .kpi-row{display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); gap:14px; margin-bottom:22px;}
  .kpi{background:#fff; border-radius:var(--radius); box-shadow:var(--shadow); padding:16px 18px; border-left:4px solid var(--denim);}
  .kpi .num{font-family:'Oswald',sans-serif; font-size:26px; font-weight:600; color:var(--navy);}
  .kpi .lbl{font-size:11px; color:var(--muted); text-transform:uppercase; letter-spacing:.05em; margin-top:2px;}
  .kpi.lime{border-color:var(--lime);}
  .kpi.purple{border-color:var(--purple);}
  .kpi.thread{border-color:var(--thread);}

  .dash-section{margin-bottom:26px;}

  /* Gantt */
  .gantt-legend{display:flex; gap:18px; margin-bottom:12px; font-size:12px; color:var(--muted); flex-wrap:wrap; align-items:center;}
  .legend-swatch{display:inline-flex; align-items:center; gap:6px;}
  .legend-swatch .sw{width:16px; height:10px; border-radius:2px; display:inline-block;}
  .gantt-scroll{overflow-x:auto; padding-bottom:6px;}
  .gantt-inner{position:relative; min-width:900px;}
  .gantt-header{display:flex; border-bottom:2px solid var(--denim); position:relative; height:30px;}
  .gantt-month{position:absolute; top:0; height:100%; border-left:1px solid var(--line); font-size:11px; color:var(--muted); padding:6px 0 0 6px; font-family:'JetBrains Mono',monospace;}
  .gantt-body{position:relative;}
  .gantt-row{display:flex; align-items:center; height:40px; border-bottom:1px solid var(--line); position:relative;}
  .gantt-row-label{position:sticky; left:0; width:190px; min-width:190px; background:#fff; z-index:2; font-size:12px; padding-right:10px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;}
  .gantt-row-label b{display:block; color:var(--navy); font-size:12.5px;}
  .gantt-row-label span{color:var(--muted); font-size:10.5px;}
  .gantt-track{position:relative; flex:1; height:100%;}
  .gantt-gridline{position:absolute; top:0; bottom:0; border-left:1px solid var(--line);}
  .gantt-today{position:absolute; top:0; bottom:0; border-left:2px solid var(--thread); z-index:3;}
  .gantt-today::after{content:"TODAY"; position:absolute; top:-30px; left:-20px; font-size:9px; color:var(--thread); font-family:'JetBrains Mono',monospace; letter-spacing:.05em;}
  .bar{position:absolute; height:9px; border-radius:5px; top:6px;}
  .bar-plan{border:1px solid rgba(0,0,0,.25);}
  .bar-plan.wm-easy{background:var(--metric-easy);}
  .bar-plan.wm-medium{background:var(--metric-medium);}
  .bar-plan.wm-hard{background:var(--metric-hard);}
  .bar-plan.wm-veryhard{background:var(--metric-veryhard);}
  .bar-actual{top:20px; height:9px; background:repeating-linear-gradient(45deg, var(--denim), var(--denim) 4px, var(--denim-dark) 4px, var(--denim-dark) 8px);}
  .bar-actual.late{background:repeating-linear-gradient(45deg, var(--hard-red), var(--hard-red) 4px, #8f2e19 4px, #8f2e19 8px);}

  .charts-row{display:grid; grid-template-columns:1.1fr 0.8fr 0.8fr; gap:20px;}
  @media (max-width:1100px){.charts-row{grid-template-columns:1fr;}}
  .bal-chart{display:flex; flex-direction:column; gap:10px;}
  .bal-item{display:grid; grid-template-columns:96px 1fr 34px; align-items:center; gap:10px; font-size:12px;}
  .bal-bar-bg{background:var(--chambray); border-radius:5px; height:14px; overflow:hidden;}
  .bal-bar-fill{height:100%; background:var(--denim); border-radius:5px;}
  .proc-list{display:flex; flex-direction:column; gap:9px;}
  .proc-item{display:flex; justify-content:space-between; align-items:center; font-size:12.5px; padding:8px 10px; background:var(--chambray); border-radius:7px;}
  .proc-item b{color:var(--navy); font-family:'Oswald',sans-serif; font-weight:600;}

  /* Delivery progress */
  .progress-list{display:flex; flex-direction:column; gap:13px;}
  .progress-row{display:grid; grid-template-columns:170px 1fr 110px 150px; gap:12px; align-items:center; font-size:12.5px;}
  @media (max-width:820px){.progress-row{grid-template-columns:1fr; gap:5px;}}
  .progress-label b{display:block; color:var(--navy); font-family:'Oswald',sans-serif; font-size:12.5px;}
  .progress-label span{color:var(--muted); font-size:10.5px;}
  .progress-bar-bg{background:var(--chambray); border-radius:7px; height:14px; overflow:hidden;}
  .progress-bar-fill{height:100%; transition:width .3s;}
  .progress-pct{text-align:right; color:var(--denim-dark); font-weight:700;}
  .progress-last{color:var(--muted); font-size:11px;}

  .empty-state{text-align:center; padding:50px 20px; color:var(--muted);}
  .empty-state .big{font-size:40px; margin-bottom:8px;}

  .toast{position:fixed; bottom:24px; right:24px; background:var(--navy); color:#fff; padding:12px 18px; border-radius:8px; font-size:13px; box-shadow:var(--shadow); opacity:0; transform:translateY(10px); transition:.25s; pointer-events:none; z-index:99;}
  .toast.show{opacity:1; transform:none;}
  .toast.err{background:var(--hard-red);}

  #configWarning{background:#fff2d6; border:1px solid #e0b050; color:#7a5510; padding:12px 16px; border-radius:8px; margin-bottom:18px; font-size:13px; display:none;}
  #configWarning code{background:rgba(0,0,0,.06); padding:1px 5px; border-radius:4px;}
</style>
</head>
<body>

<header class="top">
  <div class="brand">
    <div class="tag">DW</div>
    <div>
      <h1>Wash House Process Tracker</h1>
      <div class="sub">Prestige Clothing · Laundry Ops</div>
    </div>
  </div>
  <nav class="tabs">
    <button class="active" data-tab="jobcard">Job Card</button>
    <button data-tab="dashboard">Dashboard</button>
  </nav>
</header>

<main>
  <div id="configWarning">
    ⚠️ Supabase isn't configured yet. Open this file and set <code>SUPABASE_URL</code> and <code>SUPABASE_ANON_KEY</code>
    near the top of the <code>&lt;script&gt;</code> block. Run <code>schema.sql</code> in your Supabase project first.
  </div>

  <!-- ============ TAB 1: JOB CARD ============ -->
  <section class="tab active" id="tab-jobcard">
    <div class="jobcard-grid">

      <div class="tag-card">
        <div class="section-title"><span id="formTitle">New Job Card</span> <span class="chip" id="formModeChip">CREATE</span></div>
        <form id="jobForm">
          <div class="field-grid">
            <div class="full">
              <label>CMT Name</label>
              <input type="text" id="cmt_name" required placeholder="e.g. Denim Craft CMT">
            </div>
            <div>
              <label>Style Number</label>
              <input type="text" id="style_number" required placeholder="e.g. ST-4421">
            </div>
            <div>
              <label>Order Number</label>
              <input type="text" id="order_number" required placeholder="e.g. ORD-8801">
            </div>

            <div>
              <label>Start Date</label>
              <input type="date" id="start_date">
            </div>
            <div>
              <label>Style Delivery Date</label>
              <input type="date" id="style_delivery_date">
            </div>

            <div class="full">
              <label>Process</label>
              <input type="text" id="process" list="processList" placeholder="e.g. Stone Wash, Enzyme, PP Spray...">
              <datalist id="processList">
                <option value="Stone Wash"><option value="Enzyme Wash"><option value="Bleach Wash">
                <option value="PP Spray"><option value="Whiskering"><option value="Tack">
                <option value="Rinse"><option value="Hand Scraping"><option value="Ozone">
                <option value="Garment Dye"><option value="Laser">
              </datalist>
            </div>

            <div>
              <label>Wash Metric (Difficulty)</label>
              <select id="wash_metric">
                <option value="Easy">Easy</option>
                <option value="Medium" selected>Medium</option>
                <option value="Hard">Hard</option>
                <option value="Very Hard">Very Hard</option>
              </select>
            </div>
            <div>
              <label>Days in Washing</label>
              <input type="number" id="days_in_washing" min="0" value="0">
            </div>

            <div>
              <label>Planned Units</label>
              <input type="number" id="planned_units" min="0" value="0">
            </div>
            <div>
              <label>Units Despatched</label>
              <input type="number" id="units_despatched" min="0" value="0">
            </div>

            <div class="full">
              <label>Sample Received</label>
              <div class="radio-row">
                <label><input type="radio" name="sample_received" value="yes"> Yes</label>
                <label><input type="radio" name="sample_received" value="no" checked> No</label>
              </div>
            </div>

            <div class="full">
              <fieldset>
                <legend>Delivery Planning</legend>
                <div class="drops-table">
                  <div class="drops-head"><span>Drop</span><span>Date</span><span>Units Delivered</span><span></span></div>
                  <div id="dropsContainer"></div>
                </div>
                <button type="button" class="btn btn-ghost btn-sm" id="addDropBtn">+ Add Drop</button>
                <div class="drop-total" id="dropTotal">Total received: 0 / 0 planned (0%)</div>
                <div style="margin-top:12px; max-width:220px;">
                  <label>Last Drop Date</label>
                  <input type="date" id="last_drop_date">
                </div>
              </fieldset>
            </div>

            <div class="full">
              <fieldset>
                <legend>Balances (units outstanding)</legend>
                <div class="balance-grid">
                  <div><label>Laundry</label><input type="number" id="balance_laundry" min="0" value="0"></div>
                  <div><label>Production</label><input type="number" id="balance_production" min="0" value="0"></div>
                  <div><label>Spraying</label><input type="number" id="balance_spraying" min="0" value="0"></div>
                  <div><label>Manual</label><input type="number" id="balance_manual" min="0" value="0"></div>
                  <div><label>Laser</label><input type="number" id="balance_laser" min="0" value="0"></div>
                  <div><label>Finishing</label><input type="number" id="balance_finishing" min="0" value="0"></div>
                </div>
              </fieldset>
            </div>
          </div>

          <div class="form-actions">
            <button type="submit" class="btn btn-primary" id="submitBtn">Save Job Card</button>
            <button type="button" class="btn btn-ghost" id="cancelEditBtn" style="display:none;">Cancel Edit</button>
          </div>
        </form>
      </div>

      <div class="card" style="padding:20px 22px;">
        <div class="section-title">Job Cards <span class="chip" id="jobCountChip">0</span></div>
        <div class="table-toolbar">
          <input type="text" id="searchBox" placeholder="Search CMT, style, order...">
          <select id="filterProcess"><option value="">All Processes</option></select>
          <select id="filterMetric">
            <option value="">All Wash Metrics</option>
            <option value="Easy">Easy</option><option value="Medium">Medium</option>
            <option value="Hard">Hard</option><option value="Very Hard">Very Hard</option>
          </select>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>CMT</th><th>Style #</th><th>Order #</th><th>Process</th><th>Wash</th><th>Days Wash</th>
                <th>Delivery</th><th>Planned</th><th>Received</th><th>Despatched</th><th>Last Drop</th><th></th>
              </tr>
            </thead>
            <tbody id="jobsTableBody">
              <tr class="empty-row"><td colspan="12">No job cards yet — add one on the left.</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ TAB 2: DASHBOARD ============ -->
  <section class="tab" id="tab-dashboard">
    <div class="kpi-row">
      <div class="kpi"><div class="num" id="kpiJobs">0</div><div class="lbl">Active Job Cards</div></div>
      <div class="kpi lime"><div class="num" id="kpiPlanned">0</div><div class="lbl">Planned Units</div></div>
      <div class="kpi purple"><div class="num" id="kpiReceived">0</div><div class="lbl">Units Received</div></div>
      <div class="kpi thread"><div class="num" id="kpiDespatched">0</div><div class="lbl">Units Despatched</div></div>
      <div class="kpi" style="border-color:var(--hard-red);"><div class="num" id="kpiLate">0</div><div class="lbl">Late vs. Delivery Date</div></div>
    </div>

    <div class="dash-section card" style="padding:20px 22px;">
      <div class="section-title">Gantt — Planned vs. Actual Timeline</div>
      <div class="gantt-legend">
        <span class="legend-swatch"><span class="sw" style="background:var(--metric-easy);"></span> Easy</span>
        <span class="legend-swatch"><span class="sw" style="background:var(--metric-medium);"></span> Medium</span>
        <span class="legend-swatch"><span class="sw" style="background:var(--metric-hard);"></span> Hard</span>
        <span class="legend-swatch"><span class="sw" style="background:var(--metric-veryhard);"></span> Very Hard</span>
        <span class="legend-swatch"><span class="sw" style="background:repeating-linear-gradient(45deg,var(--denim),var(--denim) 3px,var(--denim-dark) 3px,var(--denim-dark) 6px);"></span> Actual (Start → Last Drop)</span>
        <span class="legend-swatch"><span class="sw" style="background:repeating-linear-gradient(45deg,var(--hard-red),var(--hard-red) 3px,#8f2e19 3px,#8f2e19 6px);"></span> Despatched late</span>
      </div>
      <div class="gantt-scroll">
        <div class="gantt-inner" id="ganttInner">
          <div class="empty-state" id="ganttEmpty"><div class="big">📅</div>Add job cards with a start date to see the timeline.</div>
        </div>
      </div>
    </div>

